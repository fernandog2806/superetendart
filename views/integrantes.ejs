<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Integrantes | SUPER ETENDART</title>
    <!-- La barra '/' al principio asegura que encuentre tu CSS siempre -->
    <link rel="stylesheet" href="/main.css">
    <!-- Font Awesome -->
    <link href="https://cloudflare.com" rel="stylesheet">
</head>

<body>
    <!-- El include de arriba inyecta automáticamente tu <nav> dinámico -->
    <%- include('partials/nav') %>

        <section>
            <div class="integrantes-cards">
                <!-- EJS recorre el array de músicos e inyecta los datos del servidor -->
                <% integrantes.forEach(m=> { %>
                    <div class="integrante-card">
                        <img class="integrante-foto" src="/<%= m.foto %>" alt="<%= m.nombre %>">
                        <div class="integrante-name" style="text-align: center;">
                            <h2>
                                <%= m.nombre %>
                            </h2>
                            <a class="integrante-social" href="<%= m.instagram %>" target="_blank">
                                <svg width="20" height="20" fill="#00cfff" viewBox="0 0 24 24">
                                    <path
                                        d="M12 2.1c3.2 0 3.6.0 4.9.1 1.2.1 2 .3 2.4.5.5.2.9.5 1.2.8.3.3.6.7.8 1.2.2.4.4 1.2.5 2.4.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.3 2-.5 2.4-.2.5-.5.9-.8 1.2-.3.3-.7.6-1.2.8-.4.2-1.2.4-2.4.5-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-2-.3-2.4-.5-.5-.2-.9-.5-1.2-.8-.3-.3-.6-.7-.8-1.2-.2-.4-.4-1.2-.5-2.4-.1-1.3-.1-1.7-.1-4.9s0-3.6.1-4.9c.1-1.2.3-2 .5-2.4.2-.5.5-.9.8-1.2.3-.3.7-.6 1.2-.8.4-.2 1.2-.4 2.4-.5 1.3-.1 1.7-.1 4.9-.1zM12 0C8.7 0 8.3 0 7 .1 5.8.2 4.8.4 4 .7c-.8.3-1.4.7-2.1 1.4-.7.7-1.1 1.3-1.4 2.1-.3.8-.5 1.8-.6 3C0 8.3 0 8.7 0 12s0 3.7.1 5c.1 1.2.3 2.2.6 3 .3.8.7 1.4 1.4 2.1.7.7 1.3 1.1 2.1 1.4.8.3 1.8.5 3 .6 1.3.1 1.7.1 5 .1s3.7 0 5-.1c1.2-.1 2.2-.3 3-.6.8-.3 1.4-.7 2.1-1.4.7-.7 1.1-1.3 1.4-2.1.3-.8.5-1.8.6-3 .1-1.3.1-1.7.1-5s0-3.7-.1-5c-.1-1.2-.3-2.2-.6-3-.3-.8-.7-1.4-1.4-2.1-.7-.7-1.3-1.1-2.1-1.4-.8-.3-1.8-.5-3-.6C15.7 0 15.3 0 12 0z" />
                                    <path
                                        d="M12 5.8A6.2 6.2 0 1 0 18.2 12 6.2 6.2 0 0 0 12 5.8zm0 10.2A4 4 0 1 1 16 12a4 4 0 0 1-4 4zm6.4-11.8a1.4 1.4 0 1 0 1.4 1.4 1.4 1.4 0 0 0-1.4-1.4z" />
                                </svg>
                            </a>
                        </div>
                        <p class="integrante-desc">
                            <%= m.desc %>
                        </p>
                    </div>
                    <% }) %>
            </div>
        </section>

        <%- include('partials/footer') %>

            <!-- Tu script original responsivo unwrap adaptado de manera nativa para las bios -->
            <script>
                const mediaQueryBio = window.matchMedia('(max-width: 1223px)');
                let originalHTMLBio = null;

                function unwrapBio() {
                    const container = document.querySelector('.integrantes-cards');
                    if (!container) return;
                    if (originalHTMLBio === null) originalHTMLBio = container.innerHTML;
                    const cards = container.querySelectorAll('.integrante-card');
                    cards.forEach(card => {
                        const parent = card.parentNode;
                        while (card.firstChild) parent.insertBefore(card.firstChild, card);
                        parent.removeChild(card);
                    });
                }

                function handleResizeBio(e) {
                    const container = document.querySelector('.integrantes-cards');
                    if (e.matches) { unwrapBio(); }
                    else if (container && originalHTMLBio !== null) { container.innerHTML = originalHTMLBio; }
                }

                mediaQueryBio.addEventListener('change', handleResizeBio);
                window.addEventListener('DOMContentLoaded', () => { if (mediaQueryBio.matches) unwrapBio(); });
            </script>
</body>

</html>