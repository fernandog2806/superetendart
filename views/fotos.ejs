<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fotos | SUPER ETENDART</title>
    <link rel="stylesheet" href="/main.css">
</head>

<body class="fotos-page">

    <!-- Inyectamos tu Navbar centralizado e inteligente -->
    <%- include('partials/nav') %>

        <div class="feed-container" id="feed">
            <!-- El servidor va a recorrer las fotos aquí de a 50 inicialmente -->
            <% if (typeof fotos !=='undefined' && fotos.length> 0) { %>
                <% for(let i=0; i < 50 && i < fotos.length; i++) { %>
                    <div class="foto-card">
                        <img src="/<%= fotos[i] %>" alt="Super Etendart en vivo">
                        <div class="foto-foot">
                            <button class="btn-reaccion">❤️ <span>0</span></button>
                        </div>
                    </div>
                    <% } %>
                        <% } else { %>
                            <p class="no-fotos-message">No hay fotos para mostrar todavía.</p>
                            <% } %>
        </div>

        <!-- El detector para cargar más imágenes -->
        <div id="centinela"></div>

        <%- include('partials/footer') %>

            <script src="/main.js"></script>

            <script>
                // Lógica del Scroll Infinito (Lazy Loading) del lado del navegador
                const todasLasFotos = <% - typeof fotos !== 'undefined' ? JSON.stringify(fotos) : '[]' %>;
                let mostradas = 50;
                const feed = document.getElementById('feed');
                const centinela = document.getElementById('centinela');

                function cargarMas() {
                    if (mostradas >= todasLasFotos.length) return;

                    const limite = Math.min(mostradas + 5, todasLasFotos.length);
                    for (let i = mostradas; i < limite; i++) {
                        const card = document.createElement('div');
                        card.className = 'foto-card';
                        card.innerHTML = `
                    <img src="/${todasLasFotos[i]}" alt="Super Etendart en vivo">
                    <div class="foto-foot">
                        <button class="btn-reaccion">❤️ <span>0</span></button>
                    </div>
                `;
                        feed.appendChild(card);
                    }
                    mostradas = limite;
                }

                const observer = new IntersectionObserver((entries) => {
                    if (entries.isIntersecting) cargarMas();
                }, { rootMargin: '300px' });

                if (centinela) observer.observe(centinela);
            </script>
</body>

</html>