<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nueva Contraseña | SUPER ETENDART</title>
    <link rel="stylesheet" href="/main.css">
    <style>
        body {
            background: #000;
            color: #fff;
            font-family: sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .box {
            background: #0d0d0d;
            border: 1px solid #1a1a1a;
            padding: 40px;
            border-radius: 8px;
            max-width: 400px;
            width: 100%;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.7);
            text-align: center;
        }

        h2 {
            color: #ffb703;
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        input {
            width: 100%;
            padding: 12px;
            background: #141414;
            border: 1px solid #333;
            border-radius: 4px;
            color: #fff;
            margin-bottom: 20px;
            box-sizing: border-box;
        }

        .password-container {
            position: relative;
            width: 100%;
            margin-bottom: 20px;
        }

        .password-container input {
            padding-right: 48px;
        }

        .toggle-eye {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #ccc;
            font-size: 1.1em;
            user-select: none;
            background: transparent;
            border: none;
            padding: 0;
            line-height: 1;
        }

        .toggle-eye.eye-hidden {
            text-decoration: line-through;
        }

        .toggle-eye:hover {
            color: #ffb703;
        }

        button {
            width: 100%;
            background: #ffb703;
            color: #000;
            border: none;
            padding: 14px;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>

<body>
    <div class="box">
        <h2>Nueva Contraseña</h2>
        <form action="/reset/<%= token %>" method="POST" onsubmit="return validarPasswords()">
            <div class="password-container">
                <input type="password" name="password" id="pass" placeholder="Nueva Contraseña" required>
                <span id="toggle-pass" class="toggle-eye eye-hidden">👁️</span>
            </div>
            <div class="password-container">
                <input type="password" id="pass2" placeholder="Repetir Nueva Contraseña" required>
                <span id="toggle-pass2" class="toggle-eye eye-hidden">👁️</span>
            </div>
            <button type="submit">Actualizar Contraseña</button>
        </form>
    </div>
    <script>
        const togglePass = document.getElementById('toggle-pass');
        const passInput = document.getElementById('pass');
        const togglePass2 = document.getElementById('toggle-pass2');
        const pass2Input = document.getElementById('pass2');

        togglePass.addEventListener('click', function () {
            const type = passInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passInput.setAttribute('type', type);
            this.classList.toggle('eye-hidden', type === 'password');
        });

        togglePass2.addEventListener('click', function () {
            const type = pass2Input.getAttribute('type') === 'password' ? 'text' : 'password';
            pass2Input.setAttribute('type', type);
            this.classList.toggle('eye-hidden', type === 'password');
        });

        function validarPasswords() {
            if (passInput.value !== pass2Input.value) {
                alert("Las contraseñas no coinciden.");
                return false;
            }
            return true;
        }
    </script>
</body>

</html>