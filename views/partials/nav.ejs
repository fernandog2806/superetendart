<% // Filtra el menú dinámicamente para ocultar el botón de la página en la que estás parado let
    menuFiltrado=enlacesNav.filter(enlace=> enlace.url !== paginaActual);
    %>
    <nav class="navbar">
        <div class="logo"><a href="/">SUPER ETENDART</a></div>
        <button class="hamburger" id="hamburger">☰</button>
        <ul class="nav-links">
            <% menuFiltrado.forEach(enlace=> { %>
                <% const claseAdicional=enlace.clase ? `class="${enlace.clase}" ` : "" ; %>
                    <li><a href="<%= enlace.url %>" <%- claseAdicional %>><%= enlace.texto %></a></li>
                    <% }) %>

                        <!-- BOTÓN DINÁMICO DE INICIO DE SESIÓN / USUARIO -->
                        <% if (usuarioLogueado) { %>
                            <!-- Si ya inició sesión, muestra su nombre y el botón de salir en cualquier página -->
                            <li class="user-menu" style="display: flex; align-items: center; gap: 10px;">
                                <span style="color: #ffb703; font-weight: bold;">
                                    👤 <%= usuarioLogueado.username %>
                                        <%= usuarioLogueado.rol==='dueño' ? '(Banda)' : '' %>
                                </span>
                                <a href="/logout"
                                    style="color: #ff3040; text-decoration: none; font-size: 14px;">Salir</a>
                            </li>
                            <% } else { %>
                                <!-- Si NO inició sesión, muestra el botón de ingreso, EXCEPTO en las pantallas de login y registro -->
                                <% if (paginaActual !=='/login' && paginaActual !=='/register' ) { %>
                                    <li><a href="/login" class="login-link"
                                            style="color: #ffb703; font-weight: bold;">Iniciar Sesión / Registrarse</a>
                                    </li>
                                    <% } %>
                                        <% } %>
        </ul>
        <div class="social-icons">
            <a href="https://instagram.com" target="_blank" aria-label="Instagram" class="instagram">
                <svg width="24" height="24" fill="#00cfff" viewBox="0 0 24 24">
                    <path
                        d="M12 2.2c3.2 0 3.584.012 4.85.07 1.17.056 1.97.24 2.43.41a4.92 4.92 0 0 1 1.77 1.01 4.92 4.92 0 0 1 1.01 1.77c.17.46.354 1.26.41 2.43.058 1.266.07 1.65.07 4.85s-.012 3.584-.07 4.85c-.056 1.17-.24 1.97-.41 2.43a4.92 4.92 0 0 1-1.01 1.77 4.92 4.92 0 0 1-1.77 1.01c-.46.17-1.26.354-2.43.41-1.266.058-1.65.07-4.85.07s-3.584-.012-4.85-.07c-1.17-.056-1.97-.24-2.43-.41a4.92 4.92 0 0 1-1.77-1.01 4.92 4.92 0 0 1-1.01-1.77c-.17-.46-.354-1.26-.41-2.43C2.212 15.784 2.2 15.4 2.2 12s.012-3.584.07-4.85c.056-1.17.24-1.97.41-2.43a4.92 4.92 0 0 1-1.01 1.77 4.92 4.92 0 0 0 2.56 1.64A7.07 7.07 0 0 0 .54 4.01C.312 4.77.128 5.77.07 7.052.012 8.332 0 8.736 0 12c0 3.264.012 3.668.07 4.948.058 1.282.242 2.282.47 3.042a7.07 7.07 0 0 0 1.64 2.56 7.07 7.07 0 0 0 2.56 1.64c.76.228 1.76.412 3.042.47C8.332 23.988 8.736 24 12 24s3.668-.012 4.948-.07c1.282-.058 2.282-.242 3.042-.47a7.07 7.07 0 0 0 2.56-1.64 7.07 7.07 0 0 0 1.64-2.56c.228-.76.412-1.76.47-3.042.058-1.28.07-1.684.07-4.948s-.012-3.668-.07-4.948c-.058-1.282-.242-2.282-.47-3.042a7.07 7.07 0 0 0-1.64-2.56A7.07 7.07 0 0 0 19.99.54c-.76-.228-1.76-.412-3.042-.47C15.668.012 15.264 0 12 0z" />
