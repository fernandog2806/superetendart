<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrarse | SUPER ETENDART</title>
    <link rel="stylesheet" href="/main.css">
    <style>
        body {
            background: #000;
            color: #fff;
            font-family: sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px 0;
        }

        .box {
            background: #0d0d0d;
            border: 1px solid #1a1a1a;
            padding: 40px;
            border-radius: 8px;
            max-width: 450px;
            width: 100%;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.7);
            text-align: center;
        }

        h2 {
            color: #ffb703;
            margin-bottom: 25px;
            text-transform: uppercase;
        }

        .row {
            display: flex;
            gap: 15px;
        }

        input {
            width: 100%;
            padding: 12px;
            background: #141414;
            border: 1px solid #333;
            border-radius: 4px;
            color: #fff;
            margin-bottom: 20px;
            box-sizing: border-box;
        }

        input:focus {
            border-color: #ffb703;
            outline: none;
        }

        .check-group {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
            cursor: pointer;
            justify-content: center;
        }

        .check-group input {
            width: 18px;
            height: 18px;
            accent-color: #ffb703;
            margin: 0;
        }

        button {
            width: 100%;
            background: #ffb703;
            color: #000;
            border: none;
            padding: 14px;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
            font-size: 16px;
        }

        p {
            margin-top: 20px;
            color: #888;
            font-size: 14px;
        }

        p a {
            color: #ffb703;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <%- include('partials/nav') %>

        <div class="box">
            <h2>Crear Cuenta</h2>

            <!-- 🚀 Muestra el error del servidor adentro de tu diseño si algo falla -->
            <% if (locals.error) { %>
                <div class="alerta-error"
                    style="color: #ff4a4a; background: #2a1515; padding: 12px; border-radius: 5px; margin-bottom: 20px; border: 1px solid #ff0000; font-size: 14px; text-align: center;">
                    ⚠️ <%= error %>
                </div>
                <% } %>

                    <form action="/register" method="POST" onsubmit="return validarPasswords()">
                        <div class="row">
                            <input type="text" name="nombre" placeholder="Nombre" required>
                            <input type="text" name="apellido" placeholder="Apellido" required>
                        </div>
                        <input type="text" name="username" placeholder="Nombre de Usuario" required>
                        <input type="email" name="email" placeholder="Correo Electrónico" required>

<!-- 🚀 Contraseña con Ojo Relleno y Transparente Integrado -->
                        <div class="input-contenedor" style="position: relative; width: 100%; margin-bottom: 15px;">
                            <input type="password" name="password" id="passReg" placeholder="Contraseña" required
                                style="width: 100%; padding-right: 40px; box-sizing: border-box;">
                            <button type="button" onclick="alternarOjo('passReg', this)"
                                style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; outline: none; width: 24px; height: 24px;">
                                <svg class="icono-ojo" viewBox="0 0 24 24" fill="#333333"
                                    style="width: 22px; height: 22px; pointer-events: none;">
                                    <path
                                        d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" />
                                </svg>
                            </button>
                        </div>

                        <!-- 🚀 Confirmar Contraseña con Ojo Relleno y Transparente Integrado -->
                        <div class="input-contenedor" style="position: relative; width: 100%; margin-bottom: 15px;">
                            <input type="password" name="passwordConfirm" id="passConfirm" placeholder="Confirmar Contraseña" required
                                style="width: 100%; padding-right: 40px; box-sizing: border-box;">
                            <button type="button" onclick="alternarOjo('passConfirm', this)"
                                style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; outline: none; width: 24px; height: 24px;">
                                <svg class="icono-ojo" viewBox="0 0 24 24" fill="#333333"
                                    style="width: 22px; height: 22px; pointer-events: none;">
                                    <path
                                        d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" />
                                </svg>
                            </button>
                        </div>


                        <label class="check-group" style="margin-top: 15px; display: flex; align-items: center;">
                            <input type="checkbox" name="esDueñoCheck" id="esDueñoCheck">
                            <span>Soy músico / dueño de la banda</span>
                        </label>

                        <div id="campo-codigo" style="display: none; margin-top: 15px;">
                            <div class="input-contenedor" style="position: relative; width: 100%; margin-bottom: 15px;">
                                <input type="password" name="codigoBanda" id="codigoBanda" placeholder="Código Secreto de la Banda"
                                    style="width: 100%; padding-right: 40px; box-sizing: border-box;">
                                <button type="button" onclick="alternarOjo('codigoBanda', this)"
                                    style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; outline: none; width: 24px; height: 24px;">
                                    <svg class="icono-ojo" viewBox="0 0 24 24" fill="#333333"
                                        style="width: 22px; height: 22px; pointer-events: none;">
                                        <path
                                            d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <button type="submit" style="margin-top: 20px;">Registrarme</button>
                    </form>
                    <p>¿Ya tenés cuenta? <a href="/login">Iniciá sesión</a></p>
        </div>

        <script>
            document.getElementById('esDueñoCheck').addEventListener('change', function () {
                document.getElementById('campo-codigo').style.display = this.checked ? 'block' : 'none';
            });

            function validarPasswords() {
                const p1 = document.getElementById('passReg').value;
                const p2 = document.getElementById('passConfirm').value;
                if (p1 !== p2) {
                    alert("Las contraseñas no coinciden.");
                    return false;
                }
                return true;
            }

            // 🚀 FUNCIÓN AVANZADA: Alterna el tipo de input y cambia el SVG relleno
            function alternarOjo(idInput, boton) {
                const input = document.getElementById(idInput);
                const ojoAbierto = `<svg class="icono-ojo" viewBox="0 0 24 24" fill="#333333" style="width: 22px; height: 22px; pointer-events: none;"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>`;
                const ojoTachado = `<svg class="icono-ojo" viewBox="0 0 24 24" fill="#333333" style="width: 22px; height: 22px; pointer-events: none;"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.03 2.63 3.03 4.79 5.59 6.01l-1.42 1.42 1.41 1.41 16.24-16.24-1.41-1.41-2.45 2.45A11.75 11.75 0 0 0 12 4.5zm0 4.5c.34 0 .67.04.99.11L9.11 12.99c-.07-.32-.11-.65-.11-.99 0-1.66 1.34-3 3-3zm0 8c-1.66 0-3-1.34-3-3 0-.34.04-.67.11-.99l4.88 4.88c-.32.07-.65.11-.99.11zm6.41-1.99A11.37 11.37 0 0 0 23 12c-1.73-4.39-6-7.5-11-7.5-.96 0-1.9.12-2.8.34l2.45 2.45c.11-.01.23-.03.35-.03 2.76 0 5 2.24 5 5 0 .12-.02.24-.03.35l2.45 2.45z"/></svg>`;

                if (input.type === "password") {
                    input.type = "text";
                    boton.innerHTML = ojoTachado;
                } else {
                    input.type = "password";
                    boton.innerHTML = ojoAbierto;
                }
            }
        </script>

</body>


</html>